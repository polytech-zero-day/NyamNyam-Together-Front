# 백엔드 Edge Function 베이스 URL.
#  - 로컬: supabase functions serve server --no-verify-jwt → 아래 기본값
#  - 배포: https://<project-ref>.supabase.co/functions/v1/server
VITE_API_BASE_URL=http://localhost:54321/functions/v1/server

# Supabase anon key. 게이트웨이 apikey 헤더용(로컬 --no-verify-jwt 면 비워둬도 됨).
VITE_SUPABASE_ANON_KEY=

# API 타임아웃(ms). 미지정 시 10000.
VITE_API_TIMEOUT_MS=10000

# 토스 appLogin 실패 시 /auth/dev-login 으로 우회할지(개발 편의). 운영 빌드는 false 권장.
VITE_ENABLE_DEV_LOGIN=true
